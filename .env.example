# --- HTTP service ---
MEMORY_PORT=18790
MEMORY_BIND=127.0.0.1
MEMORY_SERVICE_TOKEN=replace-me-with-shared-secret

# --- Neo4j ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j-dev
NEO4J_DATABASE=neo4j

# --- LLM adapter (extraction + dreaming) ---
MEMORY_LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_EXTRACTION_MODEL=claude-sonnet-4-6
ANTHROPIC_DREAMING_MODEL=claude-opus-4-7

# OpenAI adapter (also reused for OpenAI-compatible local servers via OPENAI_BASE_URL)
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_EXTRACTION_MODEL=gpt-4.1-mini

# --- Embedding adapter ---
MEMORY_EMBED_PROVIDER=openai
OPENAI_EMBED_MODEL=text-embedding-3-large
# MUST equal the active embedding adapter's dim. Drives vector-index size at migrate time.
# Switching dim requires drop+recreate of `memory_vectors` AND a re-embed backfill.
EMBED_DIM=1536

# --- Planned local-server adapters ---
LLAMACPP_BASE_URL=
LLAMACPP_MODEL=qwen3.5:9b-turboquant
OLLAMA_BASE_URL=
OLLAMA_EMBED_MODEL=nomic-embed-text

# --- Schedulers ---
MEMORY_DREAM_CRON=0 3 * * *
MEMORY_OBSERVATION_TTL_DAYS=7
# OKF vault sweep (backfill/repair + tombstones lapsed research). Only runs
# when OKF_ENABLED=true. Staggered off the dream cycle above.
OKF_SYNC_CRON=30 3 * * *

# --- Knowledge graph construction (dream cycle, off the hot path) ---
# Relation/triple extraction builds (:Entity)-[:RELATES]->(:Entity) edges;
# entity resolution re-embeds entities by name and links aliases with :SYNONYM.
DREAM_ENABLE_RELATION_EXTRACTION=true
DREAM_RELATION_MIN_CONFIDENCE=0.6
DREAM_ENABLE_ENTITY_RESOLUTION=true
DREAM_ENTITY_SYNONYM_THRESHOLD=0.9
DREAM_ENTITY_SYNONYM_CANDIDATES=5

# --- Fact hygiene (dream cycle) ---
# Dedup: skip a new fact whose cosine similarity to a live fact exceeds the
# threshold. Cross-scope dedup also checks the unscoped personal bucket from
# project episodes (never another project).
DREAM_DEDUP_THRESHOLD=0.92
DREAM_SUPERSEDE_VECTOR_THRESHOLD=0.85
DREAM_PROMOTE_INSIGHT_IMPORTANCE=0.85
DREAM_CROSS_SCOPE_DEDUP=true
# Pruning: importance >= exempt never auto-prunes; below it, retention follows
# an importance- and reference-scaled Ebbinghaus curve past the window.
DREAM_PRUNE_WINDOW_DAYS=30
DREAM_PRUNE_BATCH_LIMIT=1000
DREAM_PRUNE_IMPORTANCE_EXEMPT=0.75
DREAM_PRUNE_RETENTION_FLOOR=0.05
# Consolidation: merge fragment facts about one entity into a canonical fact.
DREAM_ENABLE_CONSOLIDATION=true
DREAM_CONSOLIDATION_MAX_CLUSTERS_PER_RUN=10
DREAM_CONSOLIDATION_MAX_CLUSTER_SIZE=6
DREAM_CONSOLIDATION_MIN_SIMILARITY=0.80
DREAM_CONSOLIDATION_MIN_ENTITY_FACTS=3

# --- Personalized PageRank retrieval (HippoRAG-style) ---
# OFF by default: the default recall pipeline is unchanged when disabled. When
# enabled, the dream cycle refreshes a GDS projection (requires the neo4j
# graph-data-science plugin) and `GET /recall?...&ppr=1` runs PageRank seeded
# from query-linked entities + dense hits, fused into the existing RRF results.
RETRIEVAL_ENABLE_PPR=false
RETRIEVAL_PPR_BUDGET=30
RETRIEVAL_PPR_SEED_TOP_FACTS=10
RETRIEVAL_PPR_QUERY_ENTITY_LINKS=5
RETRIEVAL_PPR_DAMPING=0.85
RETRIEVAL_PPR_MAX_ITER=20
RETRIEVAL_PPR_DAMP_FACTOR=0.5
RETRIEVAL_PPR_USE_RECOGNITION_FILTER=false

# --- OKF vault (one-way markdown projection of research + knowledge docs) ---
# When enabled, every research/knowledge create/update materializes a
# markdown file with YAML frontmatter under OKF_DIR; soft-deletes move the
# file to _trash/. Repair/backfill: pnpm okf:sync
OKF_ENABLED=false
OKF_DIR=./.okf-vault

# --- Knowledge attachments (filesystem blobs + multimodal extraction) ---
KNOWLEDGE_BLOB_DIR=./.knowledge-blobs
KNOWLEDGE_MAX_ATTACHMENT_BYTES=26214400
# Image OCR/description + audio transcription providers. 'auto' picks an
# available provider by API key; 'none' stores+serves blobs but skips text
# extraction (PDF/text always extract locally regardless).
KNOWLEDGE_VISION_PROVIDER=auto
# KNOWLEDGE_VISION_MODEL=          # defaults: anthropic→ANTHROPIC_EXTRACTION_MODEL, openai→gpt-4o-mini
KNOWLEDGE_TRANSCRIBE_PROVIDER=auto
KNOWLEDGE_TRANSCRIBE_MODEL=whisper-1
