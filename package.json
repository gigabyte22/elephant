{
  "name": "elephant",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kainappsinc/elephant.git"
  },
  "description": "Neo4j-backed long-term memory service for agent orchestrators",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "serve": "tsx scripts/serve.ts",
    "migrate": "tsx scripts/migrate.ts",
    "backfill:entity-norm": "tsx scripts/backfill-entity-norm.ts",
    "wipe": "tsx scripts/wipe.ts",
    "dream": "tsx scripts/dream.ts",
    "dev": "tsx watch scripts/serve.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "rebuild:facts": "tsx scripts/rebuild-facts.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@fastify/sensible": "^6.0.0",
    "@fastify/static": "^9.1.3",
    "croner": "^9.0.0",
    "dotenv": "^16.4.5",
    "fastify": "^5.0.0",
    "fastify-type-provider-zod": "^4.0.0",
    "ioredis": "^5.4.0",
    "neo4j-driver": "^5.26.0",
    "openai": "^4.65.0",
    "pdf-parse": "^2.4.5",
    "uuid": "^11.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/node": "^22.0.0",
    "testcontainers": "^10.13.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vitest": "^2.1.0"
  }
}
